# База данных
DATABASE_URL=sqlite:///./user.db

# Go микросервисы (для Docker)
GO_ANALYZER_URL=http://analyzer:8080
GO_SIMPLIFIER_URL=http://simplifier:8081

# Для локальной разработки (без Docker)
# GO_ANALYZER_URL=http://localhost:8080
# GO_SIMPLIFIER_URL=http://localhost:8081

# JWT Secret (ОБЯЗАТЕЛЬНО измените для продакшена!)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Путь к эмбеддингам
EMBEDDINGS_PATH=data/light_Tencent_AILab_ChineseEmbedding.bin

# Логирование
DB_ECHO=false

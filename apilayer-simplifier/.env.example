# Chinese Text Simplifier API - Переменные окружения

# ==================== Сервер ====================
# Порт для HTTP сервера
PORT=8081

# ==================== Аутентификация ====================
# Основной API ключ (обязательно измените для production!)
# Генерация: openssl rand -base64 32
API_KEY=sk_live_your-secure-api-key-here

# API ключи для разных тарифов (опционально)
API_KEY_FREE=sk_free_demo_key_12345
API_KEY_BASIC=sk_basic_demo_key_67890
API_KEY_ENTERPRISE=sk_enterprise_demo_key_abcde

# ==================== Данные ====================
# Путь к директории с данными (HSK словарь, эмбеддинги)
DATA_DIR=./data

# ==================== Эмбеддинги ====================
# Максимальный уровень HSK для загрузки эмбеддингов (1-6)
MAX_HSK_LEVEL=4

# Не загружать эмбеддинги (true/false) - для быстрого старта
NO_EMBEDDINGS=false

# ==================== Rate Limiting ====================
# Лимиты запросов в день для разных тарифов
RATE_LIMIT_FREE=100
RATE_LIMIT_BASIC=1000
RATE_LIMIT_PRO=10000
RATE_LIMIT_ENTERPRISE=100000

# ==================== Логирование ====================
# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# ==================== Production Checklist ====================
# [ ] Измените API_KEY на случайную строку
# [ ] Настройте RATE_LIMIT для вашего тарифа
# [ ] Установите LOG_LEVEL=warn для production
# [ ] Используйте HTTPS через reverse proxy (Nginx)
# [ ] Настройте мониторинг и алерты
# [ ] Регулярно обновляйте зависимости
